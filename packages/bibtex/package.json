{
  "name": "@paper-tools/bibtex",
  "version": "0.1.0",
  "description": "BibTeX generator CLI for Notion paper archives",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "paper-bib": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./lib": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@paper-tools/core": "workspace:*",
    "@paper-tools/recommender": "workspace:*",
    "commander": "^13.1.0",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^3.2.4",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
